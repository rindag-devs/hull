#!/bin/sh
set -eu
main_path="$1"
work_path="$2"
result_path="$3"
data_path="$4"

write_status() {
  status_text="$1"
  printf '%s\n' "$status_text" > "$result_path/cur_status.txt"
}

self_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
bundle_dir="$self_dir/hull-bundle"
runtime_nix_dir="$work_path/hull-nix"
if [ ! -x "$runtime_nix_dir/store@NIX_USER_CHROOT_STORE_SUFFIX@" ]; then
  write_status "Extracting runtime bundle"
  mkdir -p "$runtime_nix_dir/store"
  tar -xJf "$bundle_dir/nix-store.tar.xz" -C "$runtime_nix_dir"
fi
submission_file="$work_path/answer.code"
submission_language=$(awk '$1=="answer_language" { print $2; exit }' "$work_path/submission.conf")
self_dest=main
work_dest=work
data_dest=data
bundle_root_in_chroot="/$self_dest/hull-bundle"
submission_file_in_chroot="/$work_dest/answer.code"
work_path_in_chroot="/$work_dest"
data_path_in_chroot="/$data_dest"
inner_result_dir="$work_path/hull-uoj-result"
rm -rf "$inner_result_dir"
mkdir -p "$inner_result_dir"
result_path_in_chroot="/$work_dest/hull-uoj-result"
cache_dir="$work_path/hull-cache"
mkdir -p "$cache_dir"
export XDG_CACHE_HOME="$cache_dir"
export HOME="$work_path"
sync_inner_status() {
  inner_status_path="$inner_result_dir/cur_status.txt"
  while kill -0 "$1" 2>/dev/null; do
    if [ -f "$inner_status_path" ]; then
      cp -f "$inner_status_path" "$result_path/cur_status.txt" 2>/dev/null || true
    fi
    sleep 0.1
  done
  if [ -f "$inner_status_path" ]; then
    cp -f "$inner_status_path" "$result_path/cur_status.txt" 2>/dev/null || true
  fi
}

"$runtime_nix_dir/store@NIX_USER_CHROOT_STORE_SUFFIX@" \
  -m "$self_dir:$self_dest" \
  -m "$work_path:$work_dest" \
  -m "$data_path:$data_dest" \
  -p XDG_CACHE_HOME \
  -p HOME \
  -n "$runtime_nix_dir" \
  -- "@CUSTOM_JUDGE_RUNNER_RELATIVE@" \
  "$bundle_root_in_chroot" "$submission_file_in_chroot" "$submission_language" "$work_path_in_chroot" "$result_path_in_chroot" "$data_path_in_chroot" &
judge_pid="$!"
sync_inner_status "$judge_pid" &
sync_pid="$!"
wait "$judge_pid"
status="$?"
wait "$sync_pid" 2>/dev/null || true
if [ -d "$inner_result_dir" ]; then
  cp -f "$inner_result_dir"/* "$result_path"/ 2>/dev/null || true
  if [ -f "$inner_result_dir/std_output.txt" ]; then
    cp -f "$inner_result_dir/std_output.txt" "$work_path/std_output.txt" 2>/dev/null || true
  fi
fi
exit "$status"
